{
  "manifest_version": 3,
  "name": "Anishiki",
  "version": "1.3.1",
  "description": "Добавляет ссылку на Shikimori на страницах Anilibria. Создал Festov",
  "host_permissions": [
    "https://shikimori.io/*",
    "https://anilibria.top/*",
    "https://*.anilibria.top/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://anilibria.top/anime/releases/release/*",
        "https://*.anilibria.top/anime/releases/release/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
