{
  "manifest_version": 3,
  "name": "Anishiki",
  "version": "1.3",
  "description": "Добавляет ссылку на Shikimori на страницах Anilibria. Создал Festov",
  "host_permissions": ["https://shikimori.io/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://anilibria.top/anime/releases/release/*"],
      "js": ["content.js"]
    }
  ]
}
